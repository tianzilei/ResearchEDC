# =============================================================================
# ResearchEDC Production Environment Configuration
#
# IMPORTANT: Change ALL default passwords before deploying to production.
# This file uses :? syntax — unset vars will cause startup failure.
# =============================================================================

# ---- Database (MANDATORY - no defaults) ----
RESEARCHEDC_DB_TYPE=postgres
RESEARCHEDC_DB_HOST=postgres
RESEARCHEDC_DB_PORT=5432
RESEARCHEDC_DB_NAME=researchedc
RESEARCHEDC_DB_USER=researchedc
# WARNING: Change this immediately
RESEARCHEDC_DB_PASS=CHANGE_ME_PRODUCTION

# ---- PostgreSQL Root (MANDATORY - no defaults) ----
POSTGRES_USER=researchedc
POSTGRES_PASSWORD=CHANGE_ME_PRODUCTION
POSTGRES_DB=researchedc

# ---- Application URLs ----
RESEARCHEDC_SYS_URL=https://researchedc.example.com/MainMenu
RESEARCHEDC_ADMIN_EMAIL=admin@example.com

# ---- Session & Security ----
RESEARCHEDC_MAX_INACTIVE_INTERVAL=1800

# ---- Mail (Production SMTP) ----
RESEARCHEDC_MAIL_HOST=smtp.example.com
RESEARCHEDC_MAIL_PORT=587
RESEARCHEDC_MAIL_PROTOCOL=smtp
RESEARCHEDC_MAIL_USER=smtp_user
RESEARCHEDC_MAIL_PASS=CHANGE_ME_SMTP_PASSWORD
RESEARCHEDC_MAIL_AUTH=true
RESEARCHEDC_MAIL_STARTTLS=true

# ---- LDAP (optional) ----
RESEARCHEDC_LDAP_ENABLED=false

# ---- Logging ----
RESEARCHEDC_LOG_LEVEL=warn

# ---- Docker Images ----
RESEARCHEDC_WEB_IMAGE=researchedc-web:3.18.0

# ---- Timezone ----
TZ=UTC
