# =============================================================================
# OpenClinica Production Environment Configuration
#
# IMPORTANT: Change ALL default passwords before deploying to production.
# This file uses :? syntax — unset vars will cause startup failure.
# =============================================================================

# ---- Database (MANDATORY - no defaults) ----
OC_DB_TYPE=postgres
OC_DB_HOST=postgres
OC_DB_PORT=5432
OC_DB_NAME=openclinica
OC_DB_USER=openclinica
# WARNING: Change this immediately
OC_DB_PASS=CHANGE_ME_PRODUCTION

# ---- PostgreSQL Root (MANDATORY - no defaults) ----
POSTGRES_USER=openclinica
POSTGRES_PASSWORD=CHANGE_ME_PRODUCTION
POSTGRES_DB=openclinica

# ---- Application URLs ----
OC_SYS_URL=https://openclinica.example.com/MainMenu
OC_ADMIN_EMAIL=admin@example.com

# ---- Session & Security ----
OC_MAX_INACTIVE_INTERVAL=1800

# ---- Mail (Production SMTP) ----
OC_MAIL_HOST=smtp.example.com
OC_MAIL_PORT=587
OC_MAIL_PROTOCOL=smtp
OC_MAIL_USER=smtp_user
OC_MAIL_PASS=CHANGE_ME_SMTP_PASSWORD
OC_MAIL_AUTH=true
OC_MAIL_STARTTLS=true

# ---- LDAP (optional) ----
OC_LDAP_ENABLED=false

# ---- Logging ----
OC_LOG_LEVEL=warn

# ---- Docker Images ----
OC_WEB_IMAGE=openclinica-web:3.18.0

# ---- Timezone ----
TZ=UTC
