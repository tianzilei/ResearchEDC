# =============================================================================
# ResearchEDF Docker Compose — Environment Variables
# Copy this file to .env and adjust values for your environment
# =============================================================================

# ---- Database ----
RESEARCHEDC_DB_TYPE=postgres
RESEARCHEDC_DB_HOST=postgres
RESEARCHEDC_DB_PORT=5432
RESEARCHEDC_DB_NAME=researchedc
RESEARCHEDC_DB_USER=researchedc
RESEARCHEDC_DB_PASS=researchedc

# ---- PostgreSQL Root ----
POSTGRES_USER=researchedc
POSTGRES_PASSWORD=researchedc
POSTGRES_DB=researchedc

# ---- Application ----
RESEARCHEDC_SYS_URL=http://localhost:8080/MainMenu
RESEARCHEDC_ADMIN_EMAIL=admin@example.com
RESEARCHEDC_FILE_PATH=/opt/researchedc/data
RESEARCHEDC_LOG_DIR=/opt/researchedc/logs
RESEARCHEDC_LOG_LEVEL=info
RESEARCHEDC_MAX_INACTIVE_INTERVAL=3600

# ---- Mail (MailHog defaults for dev) ----
RESEARCHEDC_MAIL_HOST=mailhog
RESEARCHEDC_MAIL_PORT=1025
RESEARCHEDC_MAIL_PROTOCOL=smtp
RESEARCHEDC_MAIL_USER=
RESEARCHEDC_MAIL_PASS=
RESEARCHEDC_MAIL_AUTH=false
RESEARCHEDC_MAIL_STARTTLS=false

# ---- LDAP (disabled by default) ----
RESEARCHEDC_LDAP_ENABLED=false

# ---- Quartz Scheduler ----
RESEARCHEDC_QUARTZ_MISFIRE_THRESHOLD=18000000
RESEARCHEDC_QUARTZ_THREAD_COUNT=1
RESEARCHEDC_QUARTZ_THREAD_PRIORITY=5

# ---- Port mappings ----
RESEARCHEDC_WEB_PORT=8080
RESEARCHEDC_WS_PORT=8081
RESEARCHEDC_MAILHOG_HTTP_PORT=8025
RESEARCHEDC_ADMINER_PORT=8082

# ---- Timezone ----
TZ=UTC
