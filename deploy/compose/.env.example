# =============================================================================
# OpenClinica Docker Compose — Environment Variables
# Copy this file to .env and adjust values for your environment
# =============================================================================

# ---- Database ----
OC_DB_TYPE=postgres
OC_DB_HOST=postgres
OC_DB_PORT=5432
OC_DB_NAME=openclinica
OC_DB_USER=openclinica
OC_DB_PASS=openclinica

# ---- PostgreSQL Root ----
POSTGRES_USER=openclinica
POSTGRES_PASSWORD=openclinica
POSTGRES_DB=openclinica

# ---- Application ----
OC_SYS_URL=http://localhost:8080/MainMenu
OC_ADMIN_EMAIL=admin@example.com
OC_FILE_PATH=/opt/openclinica/data
OC_LOG_DIR=/opt/openclinica/logs
OC_LOG_LEVEL=info
OC_MAX_INACTIVE_INTERVAL=3600

# ---- Mail (MailHog defaults for dev) ----
OC_MAIL_HOST=mailhog
OC_MAIL_PORT=1025
OC_MAIL_PROTOCOL=smtp
OC_MAIL_USER=
OC_MAIL_PASS=
OC_MAIL_AUTH=false
OC_MAIL_STARTTLS=false

# ---- LDAP (disabled by default) ----
OC_LDAP_ENABLED=false

# ---- Quartz Scheduler ----
OC_QUARTZ_MISFIRE_THRESHOLD=18000000
OC_QUARTZ_THREAD_COUNT=1
OC_QUARTZ_THREAD_PRIORITY=5

# ---- Port mappings ----
OC_WEB_PORT=8080
OC_WS_PORT=8081
OC_MAILHOG_HTTP_PORT=8025
OC_ADMINER_PORT=8082

# ---- Timezone ----
TZ=UTC
