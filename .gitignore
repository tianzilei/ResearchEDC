# OpenClinica Git Ignore
# ======================

# Build output
/target/
*/target/
**/target/

# Maven
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml

# IDE - Eclipse
.classpath
.project
.settings/

# IDE - IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
/out/

# IDE - NetBeans
nb-configuration.xml
nbactions.xml

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
core/.DS_Store
web/.DS_Store
ws/.DS_Store

# Git merge artifacts
*.orig

# Legacy VCS artifacts (upstream OpenClinica was Mercurial)
.hgignore

# Application configuration (environment-specific)
web/src/main/resources/datainfo.properties
core/src/main/resources/datainfo.properties
ws/src/main/resources/datainfo.properties

# Release packages (binary distributions)
/Release/
*.war
*.ear
*.zip
*.tar.gz
*.deb

# AI/Agent working directories
.sisyphus/
.opencode/
.claude/

# Local development files
*.log
*.tmp
*.swp
*.swo
*~

# Test outputs
/test-output/
/surefire-reports/
/failsafe-reports/

# Node.js / Frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
frontend/dist/
frontend/node_modules/.vite/
*.tsbuildinfo

# Frontend build output copied into Spring Boot static resources
# Built at CI/deploy time via Docker multi-stage build or frontend-maven-plugin
app/src/main/resources/static/

# Environment files (keep .env.example)
.env
.env.local
.env.*.local
!.env.example

# Build and temp
*.class
temp/
.tmp/
**/catalina.home_IS_UNDEFINED/
app/$catalina.home/

# Runtime data
.pids/
.tomcat/
config/
data/

# Generated properties (produced by entrypoint.sh at container start)
app/src/main/resources/datainfo.properties
app/src/main/resources/enterprise.properties
app/src/main/resources/extract.properties

# Python / Questionnaire Service
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.venv
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
tox.ini
pip-log.txt
pip-delete-this-directory.txt

# Database
*.h2.db
*.mv.db
*.db
*.sqlite
*.sqlite3

# Java heap dumps
*.hprof
hs_err_pid*

# Spring Boot DevTools
.spring-boot-devtools.properties

# Oracle JDBC driver (PostgreSQL-only project)
*.jar

# Local Maven repository
lib/

# Docker
.docker/

# IDE - VS Code / Cursor
.vscode/
*.code-workspace

# macOS extended attributes
*.icloud

# Stale backup directories from refactoring
target-old*/
*.bak/
