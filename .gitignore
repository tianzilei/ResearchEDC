pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml

# IDE - Eclipse
.classpath
.project
.settings/

# IDE - IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
/out/

# IDE - NetBeans
nb-configuration.xml
nbactions.xml

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
core/.DS_Store
web/.DS_Store
ws/.DS_Store

# Git merge artifacts
*.orig

# Application configuration (environment-specific)
web/src/main/resources/datainfo.properties
core/src/main/resources/datainfo.properties
ws/src/main/resources/datainfo.properties

# Release packages (binary distributions)
/Release/
*.war
*.ear
*.zip
*.tar.gz

# AI/Agent working directories
.sisyphus/
.opencode/
.claude/

# Local development files
*.log
*.tmp
*.swp
*.swo
*~

