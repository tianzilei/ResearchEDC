node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
frontend/dist/
frontend/node_modules/.vite/
*.tsbuildinfo

# Environment files (keep .env.example)
.env
.env.local
.env.*.local
!.env.example

# Build and temp
*.class
temp/
.tmp/

# IDE - VS Code / Cursor
.vscode/
*.code-workspace

