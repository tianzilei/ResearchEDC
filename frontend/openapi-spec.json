{
  "openapi": "3.0.3",
  "info": {
    "title": "ResearchEDC API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/exports": {
      "get": {
        "operationId": "listExportJobs",
        "parameters": [
          { "name": "studyId", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/ExportJobStatus" } },
          { "name": "exportFormat", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/ExportFormat" } },
          { "name": "odmContractVersion", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/OdmContractVersion" } },
          { "name": "requestedBy", "in": "query", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of export jobs",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ExportJobDTO" } } } }
          }
        }
      },
      "post": {
        "operationId": "createExportJob",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateExportJobRequest" } } }
        },
        "responses": {
          "201": {
            "description": "Created export job",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExportJobDTO" } } }
          }
        }
      }
    },
    "/api/v1/exports/{id}": {
      "get": {
        "operationId": "getExportJob",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Export job details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExportJobDTO" } } }
          }
        }
      }
    },
    "/api/v1/exports/{id}/cancel": {
      "post": {
        "operationId": "cancelExportJob",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Cancelled export job",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExportJobDTO" } } }
          }
        }
      }
    },
    "/api/v1/exports/{id}/retry": {
      "post": {
        "operationId": "retryExportJob",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Retried export job",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExportJobDTO" } } }
          }
        }
      }
    },
    "/api/v1/datasets": {
      "get": {
        "operationId": "listDatasets",
        "parameters": [
          { "name": "studyId", "in": "query", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of datasets",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/DatasetDTO" } } } }
          }
        }
      },
      "post": {
        "operationId": "createDataset",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateDatasetRequest" } } }
        },
        "responses": {
          "201": {
            "description": "Created dataset",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DatasetDTO" } } }
          }
        }
      }
    },
    "/api/v1/datasets/{id}": {
      "get": {
        "operationId": "getDataset",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Dataset details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DatasetDTO" } } }
          }
        }
      }
    },
    "/api/v1/filters": {
      "get": {
        "operationId": "listFilters",
        "responses": {
          "200": {
            "description": "List of filters",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/FilterDTO" } } } }
          }
        }
      },
      "post": {
        "operationId": "createFilter",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateFilterRequest" } } }
        },
        "responses": {
          "201": {
            "description": "Created filter",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FilterDTO" } } }
          }
        }
      }
    },
    "/api/v1/filters/{id}": {
      "get": {
        "operationId": "getFilter",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Filter details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FilterDTO" } } }
          }
        }
      }
    },
    "/api/v1/randomization/schemes": {
      "get": {
        "operationId": "listSchemes",
        "parameters": [
          { "name": "studyId", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of randomization schemes",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/SchemeSummaryDTO" } } } }
          }
        }
      },
      "post": {
        "operationId": "createScheme",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SchemeDTO" } } }
        },
        "responses": {
          "201": {
            "description": "Created scheme",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SchemeDTO" } } }
          }
        }
      }
    },
    "/api/v1/randomization/schemes/{id}": {
      "get": {
        "operationId": "getScheme",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "Scheme details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SchemeDTO" } } }
          }
        }
      },
      "put": {
        "operationId": "updateScheme",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SchemeDTO" } } }
        },
        "responses": {
          "200": {
            "description": "Updated scheme",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SchemeDTO" } } }
          }
        }
      }
    },
    "/api/v1/randomization/schemes/{id}/activate": {
      "post": {
        "operationId": "activateScheme",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": { "description": "Scheme activated" }
        }
      }
    },
    "/api/v1/randomization/schemes/{id}/close": {
      "post": {
        "operationId": "closeScheme",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": { "description": "Scheme closed" }
        }
      }
    },
    "/api/v1/randomization/randomize": {
      "post": {
        "operationId": "randomize",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RandomizeRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Assignment created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AssignmentDTO" } } }
          }
        }
      }
    },
    "/api/v1/randomization/assignments": {
      "get": {
        "operationId": "listAssignments",
        "parameters": [
          { "name": "schemeId", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "List of assignments",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/AssignmentDTO" } } } }
          }
        }
      }
    },
    "/api/v1/randomization/assignments/{schemeId}/subject/{studySubjectId}": {
      "get": {
        "operationId": "getAssignment",
        "parameters": [
          { "name": "schemeId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "studySubjectId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Assignment details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AssignmentDTO" } } }
          }
        }
      }
    },
    "/api/v1/randomization/unblinding/request": {
      "post": {
        "operationId": "requestUnblinding",
        "parameters": [
          { "name": "assignmentId", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "reason", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "201": {
            "description": "Unblinding request created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UnblindingRequestDTO" } } }
          }
        }
      }
    },
    "/api/v1/randomization/unblinding/{requestId}/review": {
      "post": {
        "operationId": "reviewUnblinding",
        "parameters": [
          { "name": "requestId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "decision", "in": "query", "required": true, "schema": { "$ref": "#/components/schemas/UnblindingStatus" } },
          { "name": "reviewNotes", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Reviewed unblinding request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UnblindingRequestDTO" } } }
          }
        }
      }
    },
    "/api/v1/randomization/unblinding/requests": {
      "get": {
        "operationId": "listUnblindingRequests",
        "parameters": [
          { "name": "schemeId", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "List of unblinding requests",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/UnblindingRequestDTO" } } } }
          }
        }
      }
    },
    "/api/v1/randomization/unblinding/pending": {
      "get": {
        "operationId": "listPendingRequests",
        "responses": {
          "200": {
            "description": "List of pending unblinding requests",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/UnblindingRequestDTO" } } } }
          }
        }
      }
    },
    "/api/v1/randomization/audit": {
      "get": {
        "operationId": "getAuditLogs",
        "parameters": [
          { "name": "schemeId", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "studyId", "in": "query", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of audit logs",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/AuditLogDTO" } } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ExportFormat": {
        "type": "string",
        "enum": ["ODM_XML", "CSV", "SAS_XPORT", "EXCEL"]
      },
      "ExportJobStatus": {
        "type": "string",
        "enum": ["PENDING", "RUNNING", "COMPLETED", "FAILED", "CANCELLED"]
      },
      "OdmContractVersion": {
        "type": "string",
        "enum": ["OC2_0_COMPAT", "OC2_1"]
      },
      "ExportJobDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "studyId": { "type": "integer" },
          "name": { "type": "string" },
          "exportFormat": { "$ref": "#/components/schemas/ExportFormat" },
          "odmContractVersion": { "$ref": "#/components/schemas/OdmContractVersion" },
          "status": { "$ref": "#/components/schemas/ExportJobStatus" },
          "requestedBy": { "type": "integer" },
          "requestedDate": { "type": "string", "format": "date-time" },
          "completedDate": { "type": "string", "format": "date-time", "nullable": true },
          "filePath": { "type": "string", "nullable": true },
          "fileSize": { "type": "integer", "format": "int64", "nullable": true },
          "errorMessage": { "type": "string", "nullable": true },
          "failureCode": { "type": "string", "nullable": true },
          "retryable": { "type": "boolean", "nullable": true },
          "criteriaJson": { "type": "string", "nullable": true },
          "retryCount": { "type": "integer", "nullable": true }
        },
        "required": ["id", "studyId", "exportFormat", "status", "requestedDate"]
      },
      "CreateExportJobRequest": {
        "type": "object",
        "properties": {
          "studyId": { "type": "integer" },
          "name": { "type": "string" },
          "exportFormat": { "$ref": "#/components/schemas/ExportFormat" },
          "odmContractVersion": { "$ref": "#/components/schemas/OdmContractVersion" },
          "requestedBy": { "type": "integer" },
          "criteriaJson": { "type": "string" }
        },
        "required": ["studyId", "exportFormat"]
      },
      "DatasetDTO": {
        "type": "object",
        "properties": {
          "datasetId": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "studyId": { "type": "integer" },
          "ownerId": { "type": "integer" },
          "statusId": { "type": "integer" },
          "dateCreated": { "type": "string", "format": "date-time" }
        },
        "required": ["datasetId", "name", "studyId", "ownerId", "statusId", "dateCreated"]
      },
      "CreateDatasetRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "studyId": { "type": "integer" }
        },
        "required": ["name", "studyId"]
      },
      "FilterDTO": {
        "type": "object",
        "properties": {
          "filterId": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "ownerId": { "type": "integer" },
          "dateCreated": { "type": "string", "format": "date-time" }
        },
        "required": ["filterId", "name", "ownerId", "dateCreated"]
      },
      "CreateFilterRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["name"]
      },
      "RandomizationAlgorithm": {
        "type": "string",
        "enum": ["SIMPLE", "BLOCK", "STRATIFIED_BLOCK"]
      },
      "SchemeStatus": {
        "type": "string",
        "enum": ["DRAFT", "ACTIVE", "PAUSED", "CLOSED"]
      },
      "StratumType": {
        "type": "string",
        "enum": ["ENUM", "INTERVAL"]
      },
      "AssignmentStatus": {
        "type": "string",
        "enum": ["ACTIVE", "UNBLINDED", "REVOKED"]
      },
      "UnblindingStatus": {
        "type": "string",
        "enum": ["PENDING", "APPROVED", "REJECTED"]
      },
      "AuditAction": {
        "type": "string",
        "enum": ["SCHEME_CREATED", "SCHEME_UPDATED", "SCHEME_ACTIVATED", "SCHEME_CLOSED", "SUBJECT_RANDOMIZED", "UNBLINDING_REQUESTED", "UNBLINDING_APPROVED", "UNBLINDING_REJECTED"]
      },
      "ArmDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64", "nullable": true },
          "name": { "type": "string" },
          "displayName": { "type": "string", "nullable": true },
          "ratio": { "type": "integer" },
          "orderNumber": { "type": "integer" }
        },
        "required": ["name", "ratio", "orderNumber"]
      },
      "StratumOptionDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64", "nullable": true },
          "label": { "type": "string" },
          "value": { "type": "string" },
          "orderNumber": { "type": "integer", "nullable": true }
        },
        "required": ["label", "value"]
      },
      "StratumDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64", "nullable": true },
          "name": { "type": "string" },
          "stratumType": { "$ref": "#/components/schemas/StratumType" },
          "orderNumber": { "type": "integer" },
          "options": { "type": "array", "items": { "$ref": "#/components/schemas/StratumOptionDTO" } }
        },
        "required": ["name", "stratumType", "orderNumber", "options"]
      },
      "SchemeDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64", "nullable": true },
          "studyId": { "type": "integer" },
          "name": { "type": "string" },
          "algorithm": { "$ref": "#/components/schemas/RandomizationAlgorithm" },
          "status": { "$ref": "#/components/schemas/SchemeStatus" },
          "seed": { "type": "integer", "format": "int64", "nullable": true },
          "minBlockSize": { "type": "integer", "nullable": true },
          "maxBlockSize": { "type": "integer", "nullable": true },
          "arms": { "type": "array", "items": { "$ref": "#/components/schemas/ArmDTO" } },
          "stratifications": { "type": "array", "items": { "$ref": "#/components/schemas/StratumDTO" } },
          "totalAssigned": { "type": "integer", "format": "int64" },
          "totalArms": { "type": "integer", "format": "int64" }
        },
        "required": ["studyId", "name", "algorithm", "arms", "stratifications", "totalAssigned", "totalArms"]
      },
      "SchemeSummaryDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "studyId": { "type": "integer" },
          "name": { "type": "string" },
          "algorithm": { "$ref": "#/components/schemas/RandomizationAlgorithm" },
          "status": { "$ref": "#/components/schemas/SchemeStatus" },
          "totalAssigned": { "type": "integer", "format": "int64" },
          "totalArms": { "type": "integer" }
        },
        "required": ["id", "studyId", "name", "algorithm", "status", "totalAssigned", "totalArms"]
      },
      "RandomizeRequest": {
        "type": "object",
        "properties": {
          "schemeId": { "type": "integer", "format": "int64" },
          "studySubjectId": { "type": "integer" },
          "assignedBy": { "type": "integer", "nullable": true },
          "stratumValues": { "type": "object", "additionalProperties": { "type": "string" } }
        },
        "required": ["schemeId", "studySubjectId"]
      },
      "AssignmentDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "schemeId": { "type": "integer", "format": "int64" },
          "studySubjectId": { "type": "integer" },
          "subjectKey": { "type": "string", "nullable": true },
          "armId": { "type": "integer", "format": "int64" },
          "armName": { "type": "string" },
          "stratumPath": { "type": "string", "nullable": true },
          "status": { "$ref": "#/components/schemas/AssignmentStatus" },
          "assignedDate": { "type": "string", "format": "date-time", "nullable": true },
          "assignedBy": { "type": "integer", "nullable": true }
        },
        "required": ["id", "schemeId", "studySubjectId", "armId", "armName", "status"]
      },
      "UnblindingRequestDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "assignmentId": { "type": "integer", "format": "int64" },
          "armName": { "type": "string", "nullable": true },
          "subjectKey": { "type": "string", "nullable": true },
          "requestedBy": { "type": "integer" },
          "requestedDate": { "type": "string", "format": "date-time", "nullable": true },
          "reason": { "type": "string", "nullable": true },
          "status": { "$ref": "#/components/schemas/UnblindingStatus" },
          "reviewedBy": { "type": "integer", "nullable": true },
          "reviewedDate": { "type": "string", "format": "date-time", "nullable": true },
          "reviewNotes": { "type": "string", "nullable": true }
        },
        "required": ["id", "assignmentId", "requestedBy", "status"]
      },
      "AuditLogDTO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "schemeId": { "type": "integer", "format": "int64", "nullable": true },
          "studyId": { "type": "integer", "nullable": true },
          "action": { "$ref": "#/components/schemas/AuditAction" },
          "entityType": { "type": "string", "nullable": true },
          "entityId": { "type": "integer", "format": "int64", "nullable": true },
          "oldValue": { "type": "string", "nullable": true },
          "newValue": { "type": "string", "nullable": true },
          "performedBy": { "type": "integer", "nullable": true },
          "performedDate": { "type": "string", "format": "date-time" },
          "details": { "type": "string", "nullable": true }
        },
        "required": ["id", "action", "performedDate"]
      }
    }
  }
}
