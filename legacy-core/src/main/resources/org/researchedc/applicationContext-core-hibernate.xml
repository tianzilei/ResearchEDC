    <bean id="subjectDao" class="org.researchedc.dao.hibernate.SubjectDao" parent="abstractDomainDao" autowire="byName" />

    <bean id="viewNotesDao" class="org.researchedc.dao.managestudy.ViewNotesDaoImpl">
        <property name="dataSource" ref="dataSource"/>
        <property name="queryStore" ref="queryStore"/>
    </bean>

    <bean id="studyDaoDomain" class="org.researchedc.dao.hibernate.StudyDao" parent="abstractDomainDao" autowire="byName"/>

    <bean id="studySubjectDaoDomain" class="org.researchedc.dao.hibernate.StudySubjectDao" parent="abstractDomainDao" autowire="byName"/>
    <bean id="studyEventDefDaoDomain" class="org.researchedc.dao.hibernate.StudyEventDefinitionDao" parent="abstractDomainDao" autowire="byName"/>
    <bean id="auditLogEventDaoDomain" class="org.researchedc.dao.hibernate.AuditLogEventDao" parent="abstractDomainDao" autowire="byName"/>
    <bean id="userDaoDomain" class="org.researchedc.dao.hibernate.UserAccountDao" parent="abstractDomainDao" autowire="byName"/>
    <bean id="userTypeDao" class="org.researchedc.dao.hibernate.UserTypeDao" parent="abstractDomainDao" autowire="byName"/>
    <bean id="studyEventDaoDomain" class="org.researchedc.dao.hibernate.StudyEventDao" parent="abstractDomainDao" autowire="byName"/>
</beans>
