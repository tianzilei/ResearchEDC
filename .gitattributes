# Default to LF for repository text files. This keeps Windows and WSL/Linux
# checkouts from producing broad line-ending-only churn.
* text=auto eol=lf

# Windows command scripts conventionally use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell and project scripts must remain LF.
*.sh text eol=lf
Makefile text eol=lf

# Source and configuration files.
*.java text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.xsd text eol=lf
*.xsl text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.csv text eol=lf
*.md text eol=lf

# Binary assets and archives.
*.gif binary
*.ico binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.png binary
*.svgz binary
*.webp binary
*.zip binary
*.gz binary
*.jar binary
*.war binary
