<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <changeSet author="codex" id="2026-07-07-task-template">
        <createTable tableName="task_template">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="study_id" type="INTEGER"/>
            <column name="name" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="task_type" type="VARCHAR(60)">
                <constraints nullable="false"/>
            </column>
            <column name="default_due_days" type="INTEGER"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="INTEGER"/>
            <column name="created_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="task_template" indexName="idx_task_template_study">
            <column name="study_id"/>
        </createIndex>
    </changeSet>

    <changeSet author="codex" id="2026-07-07-task-instance">
        <createTable tableName="task_instance">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="template_id" type="BIGINT"/>
            <column name="study_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="assigned_to" type="INTEGER"/>
            <column name="title" type="VARCHAR(160)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(2000)"/>
            <column name="target_type" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="target_id" type="BIGINT"/>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="due_date" type="TIMESTAMP"/>
            <column name="created_by" type="INTEGER"/>
            <column name="created_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="completed_by" type="INTEGER"/>
            <column name="completed_date" type="TIMESTAMP"/>
            <column name="cancelled_by" type="INTEGER"/>
            <column name="cancelled_date" type="TIMESTAMP"/>
            <column name="last_reminder_date" type="TIMESTAMP"/>
            <column name="reminder_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="task_instance" indexName="idx_task_instance_study_status">
            <column name="study_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="task_instance" indexName="idx_task_instance_assigned_status">
            <column name="assigned_to"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="task_instance" indexName="idx_task_instance_due">
            <column name="due_date"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
