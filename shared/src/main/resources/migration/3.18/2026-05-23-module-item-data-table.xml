<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <!-- Phase B: Schema Ownership — module-owned item_data table -->
    <!-- The module_item_data table replaces the shared item_data table for the DataCapture Modulith module -->

    <changeSet author="research-edc" id="2026-05-23-module-item-data-seq-1">
        <comment>Create sequence for module_item_data PK</comment>
        <createSequence sequenceName="module_item_data_id_seq"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-item-data-table-2">
        <comment>Create module_item_data table with all columns matching ItemDataEntity</comment>
        <createTable tableName="module_item_data">
            <column name="item_data_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="item_id" type="INT"/>
            <column name="event_crf_id" type="INT"/>
            <column name="value" type="TEXT"/>
            <column name="ordinal" type="INT"/>
            <column name="status_id" type="INT"/>
            <column name="deleted" type="BOOLEAN"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="date_updated" type="TIMESTAMP"/>
            <column name="owner_id" type="INT"/>
            <column name="update_id" type="INT"/>
        </createTable>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-item-data-pk-3">
        <comment>Add primary key on item_data_id</comment>
        <addPrimaryKey columnNames="item_data_id" constraintName="pk_module_item_data" tableName="module_item_data"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-item-data-copy-4">
        <comment>Copy existing data from legacy item_data table to module_item_data</comment>
        <sql>
            INSERT INTO module_item_data (
                item_data_id, item_id, event_crf_id, value,
                ordinal, status_id, deleted, date_created,
                date_updated, owner_id, update_id
            )
            SELECT
                item_data_id, item_id, event_crf_id, value,
                ordinal, status_id, deleted, date_created,
                date_updated, owner_id, update_id
            FROM item_data
        </sql>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-item-data-seq-val-5">
        <comment>Set sequence to max existing item_data_id</comment>
        <sql>
            SELECT setval('module_item_data_id_seq', COALESCE((SELECT MAX(item_data_id) FROM item_data), 1))
        </sql>
    </changeSet>

</databaseChangeLog>
