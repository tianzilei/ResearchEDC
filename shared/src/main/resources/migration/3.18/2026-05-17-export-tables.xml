<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <changeSet author="openclinica" id="2026-05-17-10-create-export-job">
        <createTable tableName="export_job">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="study_id" type="INT"/>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="export_format" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="requested_by" type="INT"/>
            <column name="requested_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="completed_date" type="TIMESTAMP"/>
            <column name="file_path" type="VARCHAR(1000)"/>
            <column name="file_size" type="BIGINT"/>
            <column name="error_message" type="VARCHAR(4000)"/>
            <column name="criteria_json" type="VARCHAR(4000)"/>
            <column name="retry_count" type="INT" defaultValue="0"/>
        </createTable>
        <createIndex indexName="idx_export_job_study" tableName="export_job">
            <column name="study_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
