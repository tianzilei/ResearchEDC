<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <changeSet author="codex" id="2026-07-15-sdv-review">
        <createTable tableName="module_sdv_review">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="study_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="event_crf_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="study_subject_id" type="INTEGER"/>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="review_notes" type="VARCHAR(2000)"/>
            <column name="reviewed_by" type="INTEGER"/>
            <column name="reviewed_date" type="TIMESTAMP"/>
            <column name="created_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_date" type="TIMESTAMP"/>
        </createTable>
        <createIndex tableName="module_sdv_review" indexName="idx_sdv_review_study_status">
            <column name="study_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="module_sdv_review" indexName="idx_sdv_review_event_crf">
            <column name="event_crf_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
