<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <!-- Phase B: Schema Ownership — module-owned discrepancy_note table -->
    <!-- The module_discrepancy_note table replaces the shared discrepancy_note table for the DiscrepancyNote Modulith module -->

    <changeSet author="research-edc" id="2026-05-23-module-discrepancy-note-seq-1">
        <comment>Create sequence for module_discrepancy_note PK</comment>
        <createSequence sequenceName="module_discrepancy_note_id_seq"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-discrepancy-note-table-2">
        <comment>Create module_discrepancy_note table with all columns matching DiscrepancyNoteEntity</comment>
        <createTable tableName="module_discrepancy_note">
            <column name="discrepancy_note_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="discrepancy_note_type_id" type="INT"/>
            <column name="resolution_status_id" type="INT"/>
            <column name="detailed_notes" type="VARCHAR(1000)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="owner_id" type="INT"/>
            <column name="parent_dn_id" type="INT"/>
            <column name="entity_type" type="VARCHAR(30)"/>
            <column name="entity_id" type="INT"/>
            <column name="study_id" type="INT"/>
            <column name="assigned_user_id" type="INT"/>
        </createTable>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-discrepancy-note-pk-3">
        <comment>Add primary key on discrepancy_note_id</comment>
        <addPrimaryKey columnNames="discrepancy_note_id" constraintName="pk_module_discrepancy_note" tableName="module_discrepancy_note"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-discrepancy-note-copy-4" failOnError="false">
        <comment>Copy existing data from legacy discrepancy_note table to module_discrepancy_note</comment>
        <sql>
            INSERT INTO module_discrepancy_note (
                discrepancy_note_id, description, discrepancy_note_type_id,
                resolution_status_id, detailed_notes, date_created, owner_id,
                parent_dn_id, entity_type, entity_id, study_id, assigned_user_id
            )
            SELECT
                discrepancy_note_id, description, discrepancy_note_type_id,
                resolution_status_id, detailed_notes, date_created, owner_id,
                parent_dn_id, entity_type, NULL AS entity_id, study_id, assigned_user_id
            FROM discrepancy_note
        </sql>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-discrepancy-note-seq-val-5" failOnError="false">
        <comment>Set sequence to max existing discrepancy_note_id</comment>
        <sql>
            SELECT setval('module_discrepancy_note_id_seq', COALESCE((SELECT MAX(discrepancy_note_id) FROM discrepancy_note), 1))
        </sql>
    </changeSet>

</databaseChangeLog>
