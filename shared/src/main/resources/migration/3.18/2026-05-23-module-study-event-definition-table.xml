<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <!-- Phase B: Schema Ownership — module-owned study_event_definition table -->
    <!-- The module_study_event_definition table replaces the shared study_event_definition table for the Event Modulith module -->

    <changeSet author="research-edc" id="2026-05-23-module-study-event-def-seq-1">
        <comment>Create sequence for module_study_event_definition PK</comment>
        <createSequence sequenceName="module_study_event_definition_id_seq"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-event-def-table-2">
        <comment>Create module_study_event_definition table with all columns matching StudyEventDefinitionEntity</comment>
        <createTable tableName="module_study_event_definition">
            <column name="study_event_definition_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="study_id" type="INT"/>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(4000)"/>
            <column name="repeating" type="BOOLEAN"/>
            <column name="type" type="VARCHAR(30)"/>
            <column name="category" type="VARCHAR(30)"/>
            <column name="oc_oid" type="VARCHAR(40)"/>
            <column name="ordinal" type="INT"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="date_updated" type="TIMESTAMP"/>
            <column name="owner_id" type="INT"/>
            <column name="update_id" type="INT"/>
            <column name="status_id" type="INT"/>
        </createTable>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-event-def-pk-3">
        <comment>Add primary key on study_event_definition_id</comment>
        <addPrimaryKey columnNames="study_event_definition_id" constraintName="pk_module_study_event_def" tableName="module_study_event_definition"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-event-def-copy-4" failOnError="false">
        <comment>Copy existing data from legacy study_event_definition table to module_study_event_definition</comment>
        <sql>
            INSERT INTO module_study_event_definition (
                study_event_definition_id, study_id, name, description,
                repeating, type, category, oc_oid, ordinal,
                date_created, date_updated, owner_id, update_id, status_id
            )
            SELECT
                study_event_definition_id, study_id, name, description,
                repeating, type, category, oc_oid, ordinal,
                date_created, date_updated, owner_id, update_id, status_id
            FROM study_event_definition
        </sql>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-event-def-seq-val-5" failOnError="false">
        <comment>Set sequence to max existing study_event_definition_id</comment>
        <sql>
            SELECT setval('module_study_event_definition_id_seq', COALESCE((SELECT MAX(study_event_definition_id) FROM study_event_definition), 1))
        </sql>
    </changeSet>

</databaseChangeLog>
