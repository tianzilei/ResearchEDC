<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <!-- Phase B: Schema Ownership — module-owned subject table -->
    <!-- The module_subject table replaces the shared subject table for the Subject Modulith module -->

    <changeSet author="research-edc" id="2026-05-23-module-subject-seq-1">
        <comment>Create sequence for module_subject PK</comment>
        <createSequence sequenceName="module_subject_id_seq"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-subject-table-2">
        <comment>Create module_subject table with all columns matching SubjectEntity</comment>
        <createTable tableName="module_subject">
            <column name="subject_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="unique_identifier" type="VARCHAR(30)"/>
            <column name="date_of_birth" type="TIMESTAMP"/>
            <column name="gender" type="VARCHAR(1)"/>
            <column name="dob_collected" type="BOOLEAN"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="date_updated" type="TIMESTAMP"/>
            <column name="owner_id" type="INT"/>
            <column name="update_id" type="INT"/>
            <column name="status_id" type="INT"/>
        </createTable>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-subject-pk-3">
        <comment>Add primary key on subject_id</comment>
        <addPrimaryKey columnNames="subject_id" constraintName="pk_module_subject" tableName="module_subject"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-subject-copy-4" failOnError="false">
        <comment>Copy existing data from legacy subject table to module_subject</comment>
        <sql>
            INSERT INTO module_subject (
                subject_id, unique_identifier, date_of_birth, gender,
                dob_collected, date_created, date_updated,
                owner_id, update_id, status_id
            )
            SELECT
                subject_id, unique_identifier, date_of_birth, gender,
                dob_collected, date_created, date_updated,
                owner_id, update_id, status_id
            FROM subject
        </sql>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-subject-seq-val-5" failOnError="false">
        <comment>Set sequence to max existing subject_id</comment>
        <sql>
            SELECT setval('module_subject_id_seq', COALESCE((SELECT MAX(subject_id) FROM subject), 1))
        </sql>
    </changeSet>

</databaseChangeLog>
