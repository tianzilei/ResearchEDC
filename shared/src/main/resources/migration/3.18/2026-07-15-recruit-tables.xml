<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <changeSet author="codex" id="2026-07-15-recruit-candidate">
        <createTable tableName="module_recruit_candidate">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="study_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="candidate_code" type="VARCHAR(80)">
                <constraints nullable="false"/>
            </column>
            <column name="display_name" type="VARCHAR(160)"/>
            <column name="contact_email" type="VARCHAR(255)"/>
            <column name="contact_phone" type="VARCHAR(80)"/>
            <column name="source" type="VARCHAR(120)"/>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="VARCHAR(2000)"/>
            <column name="created_by" type="INTEGER"/>
            <column name="created_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_date" type="TIMESTAMP"/>
            <column name="converted_subject_id" type="INTEGER"/>
            <column name="converted_study_subject_id" type="INTEGER"/>
        </createTable>
        <createIndex tableName="module_recruit_candidate" indexName="idx_recruit_candidate_study_status">
            <column name="study_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="module_recruit_candidate" indexName="idx_recruit_candidate_code">
            <column name="study_id"/>
            <column name="candidate_code"/>
        </createIndex>
    </changeSet>

    <changeSet author="codex" id="2026-07-15-prescreen-result">
        <createTable tableName="module_prescreen_result">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="candidate_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="study_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="decision" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="score" type="INTEGER"/>
            <column name="criteria_summary" type="VARCHAR(2000)"/>
            <column name="review_notes" type="VARCHAR(2000)"/>
            <column name="reviewed_by" type="INTEGER"/>
            <column name="reviewed_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="module_prescreen_result" indexName="idx_prescreen_candidate">
            <column name="candidate_id"/>
            <column name="reviewed_date"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
