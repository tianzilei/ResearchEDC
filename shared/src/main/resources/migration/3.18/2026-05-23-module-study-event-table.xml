<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <!-- Phase B: Schema Ownership — module-owned study_event table -->
    <!-- The module_study_event table replaces the shared study_event table for the Event Modulith module -->

    <changeSet author="research-edc" id="2026-05-23-module-study-event-seq-1">
        <comment>Create sequence for module_study_event PK</comment>
        <createSequence sequenceName="module_study_event_id_seq"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-event-table-2">
        <comment>Create module_study_event table with all columns matching StudyEventEntity</comment>
        <createTable tableName="module_study_event">
            <column name="study_event_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="study_subject_id" type="INT"/>
            <column name="study_event_definition_id" type="INT"/>
            <column name="status_id" type="INT"/>
            <column name="subject_event_status_id" type="INT"/>
            <column name="location" type="VARCHAR(2000)"/>
            <column name="sample_ordinal" type="INT"/>
            <column name="date_start" type="TIMESTAMP"/>
            <column name="date_end" type="TIMESTAMP"/>
            <column name="start_time_flag" type="BOOLEAN"/>
            <column name="end_time_flag" type="BOOLEAN"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="date_updated" type="TIMESTAMP"/>
            <column name="owner_id" type="INT"/>
            <column name="update_id" type="INT"/>
            <column name="sed_ordinal" type="INT"/>
        </createTable>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-event-pk-3">
        <comment>Add primary key on study_event_id</comment>
        <addPrimaryKey columnNames="study_event_id" constraintName="pk_module_study_event" tableName="module_study_event"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-event-copy-4" failOnError="false">
        <comment>Copy existing data from legacy study_event table to module_study_event</comment>
        <sql>
            INSERT INTO module_study_event (
                study_event_id, study_subject_id, study_event_definition_id,
                status_id, subject_event_status_id, location, sample_ordinal,
                date_start, date_end, start_time_flag, end_time_flag,
                date_created, date_updated, owner_id, update_id, sed_ordinal
            )
            SELECT
                study_event_id, study_subject_id, study_event_definition_id,
                status_id, subject_event_status_id, location, sample_ordinal,
                date_start, date_end, start_time_flag, end_time_flag,
                date_created, date_updated, owner_id, update_id, sed_ordinal
            FROM study_event
        </sql>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-event-seq-val-5" failOnError="false">
        <comment>Set sequence to max existing study_event_id</comment>
        <sql>
            SELECT setval('module_study_event_id_seq', COALESCE((SELECT MAX(study_event_id) FROM study_event), 1))
        </sql>
    </changeSet>

</databaseChangeLog>
