<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <changeSet id="2026-06-25-export-failure-fields" author="mimocode">
        <preconditions onFail="MARK_RAN">
            <tableExists tableName="export_job"/>
            <not>
                <columnExists tableName="export_job" columnName="failure_code"/>
            </not>
        </preconditions>
        <addColumn tableName="export_job">
            <column name="failure_code" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="retryable" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
