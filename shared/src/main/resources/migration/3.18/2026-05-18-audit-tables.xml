<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="2026-05-18-01" author="sisyphus">
        <comment>Create audit_log table for the audit Modulith module</comment>
        <createTable tableName="audit_log">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="study_id" type="INT"/>
            <column name="event_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="VARCHAR(100)"/>
            <column name="entity_id" type="BIGINT"/>
            <column name="entity_label" type="VARCHAR(500)"/>
            <column name="old_value" type="TEXT"/>
            <column name="new_value" type="TEXT"/>
            <column name="performed_by" type="INT"/>
            <column name="performed_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="details" type="TEXT"/>
            <column name="source_module" type="VARCHAR(100)"/>
        </createTable>
    </changeSet>

    <changeSet id="2026-05-18-02" author="sisyphus">
        <comment>Add indexes for audit_log table</comment>
        <createIndex indexName="idx_audit_log_study_id" tableName="audit_log">
            <column name="study_id"/>
        </createIndex>
        <createIndex indexName="idx_audit_log_event_type" tableName="audit_log">
            <column name="event_type"/>
        </createIndex>
        <createIndex indexName="idx_audit_log_entity" tableName="audit_log">
            <column name="entity_type"/>
            <column name="entity_id"/>
        </createIndex>
        <createIndex indexName="idx_audit_log_performed_date" tableName="audit_log">
            <column name="performed_date"/>
        </createIndex>
        <createIndex indexName="idx_audit_log_source_module" tableName="audit_log">
            <column name="source_module"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
