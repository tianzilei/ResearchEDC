<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <!-- Phase B: Schema Ownership — module-owned study_group_class table -->
    <!-- The module_study_group_class table replaces the shared study_group_class table for the SubjectGroup Modulith module -->

    <changeSet author="research-edc" id="2026-05-23-module-study-group-class-seq-1">
        <comment>Create sequence for module_study_group_class PK</comment>
        <createSequence sequenceName="module_study_group_class_id_seq"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-group-class-table-2">
        <comment>Create module_study_group_class table with all columns matching StudyGroupClassEntity</comment>
        <createTable tableName="module_study_group_class">
            <column name="study_group_class_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(30)"/>
            <column name="study_id" type="INT"/>
            <column name="owner_id" type="INT"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="date_updated" type="TIMESTAMP"/>
            <column name="update_id" type="INT"/>
            <column name="group_class_type_id" type="INT"/>
            <column name="status_id" type="INT"/>
            <column name="subject_assignment" type="VARCHAR(30)"/>
        </createTable>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-group-class-pk-3">
        <comment>Add primary key on study_group_class_id</comment>
        <addPrimaryKey columnNames="study_group_class_id" constraintName="pk_module_study_group_class" tableName="module_study_group_class"/>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-group-class-copy-4" failOnError="false">
        <comment>Copy existing data from legacy study_group_class table to module_study_group_class</comment>
        <sql>
            INSERT INTO module_study_group_class (
                study_group_class_id, name, study_id, owner_id,
                date_created, date_updated, update_id,
                group_class_type_id, status_id, subject_assignment
            )
            SELECT
                study_group_class_id, name, study_id, owner_id,
                date_created, date_updated, update_id,
                group_class_type_id, status_id, subject_assignment
            FROM study_group_class
        </sql>
    </changeSet>

    <changeSet author="research-edc" id="2026-05-23-module-study-group-class-seq-val-5" failOnError="false">
        <comment>Set sequence to max existing study_group_class_id</comment>
        <sql>
            SELECT setval('module_study_group_class_id_seq', COALESCE((SELECT MAX(study_group_class_id) FROM study_group_class), 1))
        </sql>
    </changeSet>

</databaseChangeLog>
